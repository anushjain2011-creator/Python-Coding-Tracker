# Tic-Tac-Toe (2 Player)
board = [" "] * 9

def show():
    for i in range(0, 9, 3):
        print(board[i:i+3])

player = "X"

while " " in board:
    show()
    move = int(input("0-8: "))
    if board[move] == " ":
        board[move] = player
        player = "O" if player == "X" else "X"

print("Game Over")

