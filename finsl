# Package Dependency Resolver
packages = {
    "app":["numpy","pandas"],
    "numpy":["python"],
    "pandas":["numpy"]
}

def install(pkg, done=set()):
    if pkg not in done:
        for dep in packages.get(pkg,[]):
            install(dep, done)
        done.add(pkg)
        print("Install:", pkg)

install("app")

