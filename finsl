# N-Queens Solver
N=4

def place(row,cols):
    if row==N:
        print(cols)
        return

    for col in range(N):
        if col not in cols:
            place(row+1,cols+[col])

place(0,[])

# Mandelbrot Fractal Generator
import matplotlib.pyplot as plt

x=[]
y=[]

for a in range(-100,100):
    for b in range(-100,100):
        c=complex(a/50,b/50)
        z=0

        for i in range(20):
            z=z*z+c

        if abs(z)<2:
            x.append(a)
            y.append(b)

plt.scatter(x,y,s=1)
plt.show()

# Genetic Algorithm Puzzle Solver
import random

target="hello"

population=[
"".join(random.choice("abcdefghijklmnopqrstuvwxyz") for _ in target)
for _ in range(10)
]

for generation in range(100):
    population.sort(
        key=lambda x:sum(a!=b for a,b in zip(x,target))
    )

    if population[0]==target:
        break

    population=population[:5]+[
        "".join(random.choice("abcdefghijklmnopqrstuvwxyz") for _ in target)
        for _ in range(5)
    ]

print(population[0])

# Neural Network Trained on Custom Data
import numpy as np

X=np.array([[0,0],[0,1],[1,0],[1,1]])
y=np.array([[0],[1],[1],[0]])

weights=np.random.rand(2,1)

for _ in range(1000):
    output=X.dot(weights)
    error=y-output
    weights+=X.T.dot(error)*0.01

print(weights)
