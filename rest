# Rock Paper Scissors AI
import random

history = []
choices = ["rock","paper","scissors"]

while True:
    user = input("Choice: ")
    history.append(user)
    computer = random.choice(choices)
    print("Computer:", computer)

# Spam Email Classifier
text = input("Email: ").lower()

spam = ["free","winner","money","offer"]

if any(word in text for word in spam):
    print("Spam")
else:
    print("Not Spam")

