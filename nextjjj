# Static Site Generator
import markdown
import os

os.makedirs("site", exist_ok=True)

for file in os.listdir("."):
    if file.endswith(".md"):
        html = markdown.markdown(open(file).read())
        open(f"site/{file[:-3]}.html","w").write(html)
