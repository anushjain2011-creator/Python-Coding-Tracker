    if input(q) == a:
        score += 1

print("Score:", score)

# Caesar Cipher
text = input("Text: ")
shift = 3

result = ""

for c in text:
    if c.isalpha():
        base = ord("A") if c.isupper() else ord("a")
        result += chr((ord(c)-base+shift)%26+base)
    else:
        result += c

print(result)

