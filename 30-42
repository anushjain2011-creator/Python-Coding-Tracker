pygame.init()
screen = pygame.display.set_mode((600,400))
ball = pygame.Vector2(100,200)
vel = pygame.Vector2(4,3)

while True:
    for e in pygame.event.get():
        if e.type == pygame.QUIT:
            pygame.quit()
            quit()

    ball += vel
    if ball.x < 10 or ball.x > 590:
        vel.x *= -1
    if ball.y < 10 or ball.y > 390:
        vel.y *= -1

