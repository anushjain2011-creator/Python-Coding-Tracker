# Bouncing Ball Physics
import turtle

ball = turtle.Turtle(shape="circle")
ball.penup()

dx, dy = 3, 3

while True:
    x, y = ball.position()
    if abs(x) > 290:
        dx *= -1
    if abs(y) > 290:
        dy *= -1
    ball.goto(x + dx, y + dy)

