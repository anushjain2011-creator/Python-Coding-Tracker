# Solar System Orbit Simulator
import pygame, math

pygame.init()
screen = pygame.display.set_mode((500,500))
angle = 0

while True:
    for e in pygame.event.get():
        if e.type == pygame.QUIT:
            pygame.quit()
            quit()

    angle += 0.02

    x = 250 + math.cos(angle) * 120
    y = 250 + math.sin(angle) * 120

    screen.fill((0,0,0))
    pygame.draw.circle(screen,(255,255,0),(250,250),20)
    pygame.draw.circle(screen,(0,0,255),(int(x),int(y)),8)
    pygame.display.flip()

