# Face Detection with Webcam
import cv2

cam = cv2.VideoCapture(0)
face = cv2.CascadeClassifier(cv2.data.haarcascades +
                             "haarcascade_frontalface_default.xml")

while True:
    ok, frame = cam.read()
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

    for (x, y, w, h) in face.detectMultiScale(gray, 1.3, 5):
        cv2.rectangle(frame, (x, y), (x+w, y+h), (255,0,0), 2)

    cv2.imshow("Face Detection", frame)

    if cv2.waitKey(1) == 27:
        break

cam.release()
cv2.destroyAllWindows()

# Self-Driving Car in a Simulator (Basic RL Skeleton)
import gymnasium as gym

env = gym.make("CartPole-v1")

obs, _ = env.reset()

for _ in range(500):
    action = env.action_space.sample()
    obs, reward, done, truncated, info = env.step(action)
    if done or truncated:
        obs, _ = env.reset()

env.close()

# Custom Neural Network from Scratch
import random
import math

weights = [random.random(), random.random()]
bias = random.random()

x = [2, 3]

output = sum(a*b for a,b in zip(x,weights)) + bias
output = 1/(1+math.exp(-output))

print(output)

